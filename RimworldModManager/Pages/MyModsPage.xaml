<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RimworldModManager.Pages.MyModsPage"
             BackgroundColor="#0A0A0A">
    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="16">

        <VerticalStackLayout Grid.Row="0" Spacing="16">
            <Label x:Name="MyModsTitleLabel"
                   Text="📁 Мои моды"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="#00FF7F"
                   HorizontalOptions="Center"
                   Margin="0,16,0,0" />

            <Frame x:Name="FolderFrame"
                   BackgroundColor="#141414" BorderColor="#2A2A2A"
                   CornerRadius="10" Padding="14">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="FolderPathLabel"
                           Text="{Binding FolderPath, StringFormat='Папка: {0}'}"
                           TextColor="#AAAAAA" FontSize="12"
                           LineBreakMode="MiddleTruncation" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Button x:Name="PickFolderBtn"
                                Grid.Column="0"
                                Text="📂 Выбрать папку модов"
                                Command="{Binding PickFolderCommand}"
                                BackgroundColor="#141414" TextColor="#00FF7F"
                                BorderColor="#00FF7F" BorderWidth="1"
                                CornerRadius="8" HeightRequest="44" />
                        <Button x:Name="RefreshBtn"
                                Grid.Column="1"
                                Text="🔄"
                                Command="{Binding RefreshCommand}"
                                BackgroundColor="#1E1E1E" TextColor="#888"
                                BorderColor="#2A2A2A" BorderWidth="1"
                                CornerRadius="8" HeightRequest="44" WidthRequest="48" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Mods}">
            <CollectionView.EmptyView>
                <Label x:Name="EmptyModsLabel"
                       Text="Моды не найдены. Выберите папку Mods из RimWorld."
                       TextColor="#555" FontSize="13"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,20,0,0" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#141414" BorderColor="#2A2A2A"
                           CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <BoxView Grid.Column="0"
                                     WidthRequest="4"
                                     BackgroundColor="#00FF7F"
                                     CornerRadius="2"
                                     VerticalOptions="Fill" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding Name}"
                                       TextColor="White"
                                       FontSize="14" FontAttributes="Bold" />
                                <Label Text="{Binding Author, StringFormat='Автор: {0}'}"
                                       TextColor="#AAAAAA" FontSize="12" />
                                <Label Text="{Binding Version, StringFormat='Версия: {0}'}"
                                       TextColor="#555" FontSize="11" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>