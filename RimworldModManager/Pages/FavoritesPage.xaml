<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RimworldModManager.Pages.FavoritesPage"
             x:Name="ThisPage"
             BackgroundColor="#0A0A0A">
    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="12">

        <Label x:Name="FavTitleLabel"
               Grid.Row="0"
               Text="💚 Избранное"
               FontSize="20" FontAttributes="Bold"
               TextColor="#00FF7F"
               HorizontalOptions="Center"
               Margin="0,16,0,0" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Favorites}">
            <CollectionView.EmptyView>
                <Label x:Name="EmptyLabel"
                       Text="Нет избранных модов. Найди мод и нажми на сердечко"
                       TextColor="#555" FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,40,0,0" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#141414" BorderColor="#2A2A2A"
                           CornerRadius="10" Padding="14" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0"
                                   Text="{Binding .}"
                                   TextColor="White" FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="Steam"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.OpenSteamCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#1E1E1E" TextColor="#00FF7F"
                                    BorderColor="#00FF7F" BorderWidth="1"
                                    CornerRadius="6" HeightRequest="36" FontSize="12" />
                            <Button Grid.Column="2"
                                    Text="top-mods"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.OpenTopModsCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#1E1E1E" TextColor="#00FF7F"
                                    BorderColor="#00FF7F" BorderWidth="1"
                                    CornerRadius="6" HeightRequest="36" FontSize="12" />
                            <Button Grid.Column="3"
                                    Text="✕"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.RemoveCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#1E1E1E" TextColor="#555"
                                    BorderColor="#333" BorderWidth="1"
                                    CornerRadius="6" HeightRequest="36" WidthRequest="36"
                                    FontSize="12" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>